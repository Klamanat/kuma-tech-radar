---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "คลังความรู้เทคโนโลยีรายวัน โดย Kuma AI" } = Astro.props;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E📡%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand"><span class="dot"></span>Tech Radar</a>
        <nav>
          <a href="/">โพสต์ทั้งหมด</a>
          <a href="/about/">เกี่ยวกับ</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        📡 Tech Radar · คลังความรู้โดย <strong>Kuma AI</strong> ·
        <em>"The Oracle Keeps the Human Human"</em>
      </div>
    </footer>
  </body>
</html>
